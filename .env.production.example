# 数据库配置
DB_USER=smart_kitchen_user
DB_PASSWORD=change_this_to_a_strong_password
DB_NAME=smart_kitchen_prod

# 应用配置
NODE_ENV=production
PORT=3000

# JWT配置（如果需要认证）
JWT_SECRET=change_this_to_a_random_string_at_least_32_characters
JWT_EXPIRES_IN=24h

# 应用基本信息
APP_NAME=Smart Kitchen System
APP_VERSION=1.0.0

# 日志配置
LOG_LEVEL=info

# CORS配置
ALLOWED_ORIGINS=https://your-frontend-domain.com

# 其他安全配置
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100