<template>
  <div v-if="visible" class="fixed inset-0 bg-black bg-opacity-50 flex items-end z-50">
    <div class="bg-white w-full rounded-t-2xl max-h-[90vh] flex flex-col">
      <!-- 头部 -->
      <div class="p-4 border-b flex items-center justify-between">
        <h2 class="text-xl font-bold text-gray-900">订单录入</h2>
        <button 
          @click="closeModal"
          class="p-2 rounded-full hover:bg-gray-100 transition-colors"
        >
          <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- 输入区域 -->
      <div class="flex-1 overflow-y-auto p-4 space-y-4">
        <!-- 桌号输入 -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">桌号</label>
          <input
            v-model="tableNumber"
            type="text"
            placeholder="请输入桌号"
            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
        </div>

        <!-- 人数输入 -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">用餐人数</label>
          <input
            v-model.number="personCount"
            type="number"
            min="1"
            placeholder="请输入用餐人数"
            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
        </div>

        <!-- 菜品输入 -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">菜品</label>
          
          <!-- 菜品搜索区域 -->
          <div class="mb-3 relative">
            <div class="relative">
              <input
                v-model="searchQuery"
                type="text"
                placeholder="搜索菜品..."
                @focus="showSearchResults = true"
                @blur="handleSearchBlur"
                @input="handleSearchInput"
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 pr-10"
              >
              <button 
                v-if="searchQuery"
                @click="clearSearch"
                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            
            <!-- 搜索结果下拉框 -->
            <div 
              v-show="showSearchResults && searchResults.length > 0"
              class="absolute z-10 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-60 overflow-y-auto"
            >
              <div 
                v-for="dish in searchResults" 
                :key="dish.id"
                @click="selectDish(dish)"
                class="px-4 py-3 hover:bg-gray-50 cursor-pointer border-b border-gray-100 last:border-b-0 flex justify-between items-center"
              >
                <div>
                  <div class="font-medium text-gray-900">{{ dish.name }}</div>
                  <div class="text-sm text-gray-500">{{ dish.category?.name || '未分类' }} · {{ dish.station?.name || '未知工位' }}</div>
                </div>
                <div class="text-xs text-gray-400">
                  {{ dish.shortcutCode || '' }}
                </div>
              </div>
              <div 
                v-if="searchResults.length === 0 && searchQuery"
                class="px-4 py-3 text-gray-500 text-center"
              >
                未找到相关菜品
              </div>
            </div>
          </div>

          <!-- 已选菜品列表 -->
          <div class="space-y-2">
            <div 
              v-for="(selectedDish, index) in selectedDishes" 
              :key="selectedDish.id"
              class="flex items-center space-x-2 p-3 bg-blue-50 rounded-lg border border-blue-100"
            >
              <div class="flex-1">
                <div class="font-medium text-gray-900">{{ selectedDish.name }}</div>
                <div class="text-sm text-gray-500">{{ selectedDish.category?.name }} · {{ selectedDish.station?.name }}</div>
              </div>
              <input
                v-model.number="selectedDish.quantity"
                type="number"
                min="1"
                class="w-16 px-2 py-1 bg-white border border-gray-200 rounded text-center"
              >
              <button 
                @click="removeSelectedDish(index)"
                class="p-1 text-red-500 hover:text-red-700"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
              </button>
            </div>
            
            <!-- 手动添加菜品 -->
            <div class="border-2 border-dashed border-gray-300 rounded-lg p-4">
              <div class="text-center text-gray-500 mb-2">或手动添加菜品</div>
              <div class="flex items-center space-x-2">
                <input
                  v-model="manualDishName"
                  type="text"
                  placeholder="菜品名称"
                  class="flex-1 px-3 py-2 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
                <input
                  v-model.number="manualQuantity"
                  type="number"
                  min="1"
                  placeholder="数量"
                  class="w-20 px-3 py-2 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
                <button 
                  @click="addManualDish"
                  :disabled="!manualDishName.trim()"
                  :class="[
                    'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                    manualDishName.trim()
                      ? 'bg-blue-500 text-white hover:bg-blue-600'
                      : 'bg-gray-300 text-gray-500 cursor-not-allowed'
                  ]"
                >
                  添加
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- 备注 -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">备注</label>
          <textarea
            v-model="remark"
            rows="3"
            placeholder="特殊要求或备注..."
            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
          ></textarea>
        </div>
      </div>

      <!-- 底部按钮区域 -->
      <div class="p-4 border-t bg-gray-50 space-y-3">
        <div class="flex space-x-3">
          <button 
            @click="voiceInput"
            class="flex-1 py-3 bg-gray-200 text-black rounded-lg font-medium hover:bg-gray-300 transition-colors"
          >
            语音录入
          </button>
          <button 
            @click="photoRecognition"
            class="flex-1 py-3 bg-gray-200 text-black rounded-lg font-medium hover:bg-gray-300 transition-colors"
          >
            拍照识别
          </button>
        </div>
        <div class="flex space-x-3">
          <button 
            @click="cancel"
            class="flex-1 py-3 bg-gray-200 text-black rounded-lg font-medium hover:bg-gray-300 transition-colors"
          >
            取消
          </button>
          <button 
            @click="submit"
            :disabled="!canSubmit"
            :class="[
              'flex-1 py-3 rounded-lg font-medium transition-colors',
              canSubmit
                ? 'bg-blue-500 text-white hover:bg-blue-600'
                : 'bg-gray-300 text-gray-500 cursor-not-allowed'
            ]"
          >
            完成
          </button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, watch, onMounted } from 'vue'
import { DishService } from '@/services'

// Props
const props = defineProps({
  visible: {
    type: Boolean,
    default: false
  }
})

// Emits
const emit = defineEmits(['update:visible', 'submit', 'close'])

// 状态
const tableNumber = ref('')
const personCount = ref(1)
const remark = ref('')
const selectedDishes = ref([])
const manualDishName = ref('')
const manualQuantity = ref(1)

// 搜索相关状态
const searchQuery = ref('')
const searchResults = ref([])
const showSearchResults = ref(false)
const allDishes = ref([])

// 防抖定时器
let searchTimer = null

// 计算属性
const canSubmit = computed(() => {
  return tableNumber.value && 
         personCount.value > 0 && 
         (selectedDishes.value.length > 0 || manualDishName.value.trim())
})

// 防抖搜索函数
const handleSearchInput = () => {
  // 清除之前的定时器
  if (searchTimer) {
    clearTimeout(searchTimer)
  }
  
  // 设置新的定时器
  searchTimer = setTimeout(async () => {
    if (searchQuery.value.trim()) {
      try {
        searchResults.value = await DishService.searchDishes(searchQuery.value)
        showSearchResults.value = true
      } catch (error) {
        console.error('搜索菜品失败:', error)
        searchResults.value = []
      }
    } else {
      searchResults.value = []
    }
  }, 300)
}
```

```vue
<<<<<<< SEARCH
const handleSearchInput = () => {
  debouncedSearch()
}

// 方法
const closeModal = () => {
  emit('update:visible', false)
  emit('close')
}

const handleSearchBlur = () => {
  // 延迟隐藏搜索结果，让用户有时间点击结果
  setTimeout(() => {
    showSearchResults.value = false
  }, 200)
}

const clearSearch = () => {
  searchQuery.value = ''
  searchResults.value = []
}

const selectDish = (dish) => {
  // 检查是否已选择该菜品
  const existingIndex = selectedDishes.value.findIndex(d => d.id === dish.id)
  if (existingIndex >= 0) {
    // 如果已存在，增加数量
    selectedDishes.value[existingIndex].quantity += 1
  } else {
    // 如果不存在，添加新菜品
    selectedDishes.value.push({
      ...dish,
      quantity: 1
    })
  }
  
  // 清空搜索
  clearSearch()
}

const removeSelectedDish = (index) => {
  selectedDishes.value.splice(index, 1)
}

const addManualDish = () => {
  if (manualDishName.value.trim()) {
    selectedDishes.value.push({
      id: `manual_${Date.now()}`,
      name: manualDishName.value.trim(),
      quantity: manualQuantity.value,
      isManual: true
    })
    
    // 清空手动输入
    manualDishName.value = ''
    manualQuantity.value = 1
  }
}

const voiceInput = () => {
  console.log('语音录入功能')
  // 这里可以集成语音识别API
}

const photoRecognition = () => {
  console.log('拍照识别功能')
  // 这里可以集成OCR识别API
}

const cancel = () => {
  resetForm()
  closeModal()
}

const submit = () => {
  if (!canSubmit.value) return
  
  const orderData = {
    tableNumber: tableNumber.value,
    personCount: personCount.value,
    remark: remark.value,
    dishes: selectedDishes.value.map(dish => ({
      dishId: dish.isManual ? null : dish.id,
      name: dish.name,
      quantity: dish.quantity,
      isManual: dish.isManual || false
    }))
  }
  
  emit('submit', orderData)
  resetForm()
  closeModal()
}

const resetForm = () => {
  tableNumber.value = ''
  personCount.value = 1
  remark.value = ''
  selectedDishes.value = []
  manualDishName.value = ''
  manualQuantity.value = 1
  searchQuery.value = ''
  searchResults.value = []
  showSearchResults.value = false
}

// 初始化加载菜品数据
const loadDishes = async () => {
  try {
    allDishes.value = await DishService.getAllDishes()
  } catch (error) {
    console.error('加载菜品数据失败:', error)
  }
}

// 监听visible变化
watch(() => props.visible, (newVal) => {
  if (newVal) {
    // 模态框打开时加载菜品数据
    loadDishes()
  } else {
    resetForm()
  }
})

// 组件挂载时初始化
onMounted(() => {
  if (props.visible) {
    loadDishes()
  }
})
</script>

