# Environment variables declared in this file are automatically loaded by Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# =============================================================================
# 数据库连接配置
# =============================================================================

# 云生产环境数据库连接 (默认使用) - 使用项目根目录的正确配置
DB_HOST=8.145.34.30
DB_PORT=5432
DB_USER=smart_admin
DB_PASSWORD=13814349230cX
DB_NAME=smart_kitchen
# 直接使用解析后的URL，避免变量嵌套问题
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public&connect_timeout=30&pool_timeout=30

# 本地开发环境数据库连接 (如有需要可启用)
# DATABASE_URL="postgresql://postgres:13814349230cX@localhost:5432/smart_kitchen_dev?schema=public"

# 数据库适配器配置 (保持与DATABASE_URL一致)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public&connect_timeout=30&pool_timeout=30

# =============================================================================
# 应用环境配置
# =============================================================================

# 应用运行环境
NODE_ENV=production

# 应用端口
PORT=3001

# 应用密钥 (用于JWT签名等)
APP_SECRET="your-secret-key-here-change-in-production"

# =============================================================================
# 数据库连接池配置
# =============================================================================

# 连接池最大连接数
DB_POOL_MAX=20

# 连接池最小连接数
DB_POOL_MIN=5

# 连接超时时间 (毫秒)
DB_CONNECT_TIMEOUT=5000

# 空闲连接超时时间 (毫秒)
DB_IDLE_TIMEOUT=30000

# =============================================================================
# 日志配置
# =============================================================================

# 日志级别 (error, warn, info, debug)
LOG_LEVEL=info

# 是否启用详细查询日志
QUERY_LOGGING=false

# =============================================================================
# 监控和健康检查配置
# =============================================================================

# 健康检查端点启用
HEALTH_CHECK_ENABLED=true

# 监控检查间隔 (毫秒)
MONITOR_INTERVAL=30000

# 性能阈值配置
PERFORMANCE_THRESHOLD_WARNING=1000  # 警告阈值 (毫秒)
PERFORMANCE_THRESHOLD_ERROR=3000    # 错误阈值 (毫秒)

# =============================================================================
# 安全配置
# =============================================================================

# 是否启用SSL连接 (生产环境建议启用)
DB_SSL_ENABLED=true

# SSL证书路径 (如需要)
# DB_SSL_CERT_PATH=/path/to/cert.pem

# 是否验证SSL证书
DB_SSL_REJECT_UNAUTHORIZED=true

# =============================================================================
# 备份和恢复配置
# =============================================================================

# 自动备份启用
AUTO_BACKUP_ENABLED=false

# 备份保留天数
BACKUP_RETENTION_DAYS=7

# 备份执行时间 (cron格式)
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点

# =============================================================================
# 开发和调试配置
# =============================================================================

# 开发模式启用 (会显示更多信息)
DEVELOPMENT_MODE=false

# 是否启用数据库工具箱
DB_TOOLBOX_ENABLED=true

# 工具箱监听端口
DB_TOOLBOX_PORT=3001

# =============================================================================
# 示例配置 (请根据实际情况修改)
# =============================================================================

# 本地开发环境示例
# DATABASE_URL="postgresql://postgres:your_local_password@localhost:5432/smart_kitchen_dev?schema=public"

# 测试环境示例
# DATABASE_URL="postgresql://test_user:test_password@test-server:5432/smart_kitchen_test?schema=public"

# 多环境配置示例
# if [ "$NODE_ENV" = "development" ]; then
#   export DATABASE_URL="postgresql://postgres:dev_password@localhost:5432/smart_kitchen_dev"
# elif [ "$NODE_ENV" = "production" ]; then
#   export DATABASE_URL="postgresql://prod_user:prod_password@prod-server:5432/smart_kitchen_prod"
# fi