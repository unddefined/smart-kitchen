// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 用户表
model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  tel       String?  @db.VarChar(20)
  avatar    String?
  station   String?  @db.VarChar(50)
  password  String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

// 工位表
model Station {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  dishes    Dish[]
  @@map("stations")
}

// 菜品分类表
model DishCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?
  displayOrder Int     @default(0) @map("display_order")
  createdAt   DateTime @default(now()) @map("created_at")

  dishes      Dish[]
  @@map("dish_categories")
}

// 菜品表
model Dish {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(100)
  stationId   Int          @map("station_id")
  categoryId  Int          @map("category_id")
  shortcutCode String?     @db.VarChar(20) @map("shortcut_code")
  recipe      String?
  createdAt   DateTime     @default(now()) @map("created_at")

  station     Station      @relation(fields: [stationId], references: [id])
  category    DishCategory @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]

  @@map("dishes")
}

// 订单表
model Order {
  id          Int         @id @default(autoincrement())
  hallNumber  String      @db.VarChar(20) @map("hall_number")
  peopleCount Int         @map("people_count")
  tableCount  Int         @default(1) @map("table_count")
  status      String      @default("created") @db.VarChar(20)
  createdAt   DateTime    @default(now()) @map("created_at")
  mealTime    String?     @db.VarChar(50) @map("meal_time")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")

  orderItems  OrderItem[]
  @@map("orders")
}

// 订单菜品表
model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  dishId    Int      @map("dish_id")
  quantity  Int      @default(1)
  weight    String?  @db.VarChar(20)
  status    String   @default("pending") @db.VarChar(20)
  priority  Int      @default(0)
  remark    String?
  countable Boolean  @default(false)
  servedAt  DateTime? @map("served_at")
  createdAt DateTime @default(now()) @map("created_at")

  order     Order    @relation(fields: [orderId], references: [id])
  dish      Dish     @relation(fields: [dishId], references: [id])

  @@map("order_items")
}

// 菜谱表
model Recipe {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  description   String?
  ingredientList String?  @db.Text @map("ingredient_list")
  images        String[]
  steps         String?   @db.Text
  tags          String[]
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("recipes")
}