// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// 用户表
model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  tel       String?  @db.VarChar(20)
  avatar    String?
  station   String?  @db.VarChar(50)
  password  String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

// 工位表
model Station {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  dishes Dish[]

  @@map("stations")
}

// 菜品分类表
model DishCategory {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(50)
  description  String?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  dishes Dish[]

  @@map("dish_categories")
}

// 菜品表
model Dish {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100)
  stationId    Int      @map("station_id")
  categoryId   Int      @map("category_id")
  shortcutCode String?  @map("shortcut_code") @db.VarChar(20)
  recipeId     Int?     @map("recipe_id") // 添加菜谱关联字段
  countable    Boolean  @default(false) // 是否计数，比如托炉饼一份需按一桌的人数计数
  needPrep     Boolean  @default(false) @map("need_prep") // 是否需要预处理（如裹粉、蒸、预炸），如否则跳过status.prep
  isActive     Boolean  @default(true) @map("is_active") // 启用或禁用菜品
  createdAt    DateTime @default(now()) @map("created_at")

  station    Station      @relation(fields: [stationId], references: [id])
  category   DishCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("dishes")
}

// 订单表
model Order {
  id          Int       @id @default(autoincrement())
  hallNumber  String    @map("hall_number") @db.VarChar(20)
  peopleCount Int       @map("people_count")
  tableCount  Int       @default(1) @map("table_count")
  status      String    @default("created") @db.VarChar(20) // created → started → serving → urged → done → cancelled
  createdAt   DateTime  @default(now()) @map("created_at")
  mealTime    DateTime? @map("meal_time") // 用餐时间（年月日时分）⭐ 使用TIMESTAMP类型
  mealType    String?   @map("meal_type") @db.VarChar(10) // 用餐时间（午/晚/打包）
  startTime   DateTime? @map("start_time") // 起菜时间（若为打包菜，start_time = meal_time）
  remark      String?   @db.Text // 备注
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@map("orders")
}

// 订单菜品表
model OrderItem {
  id        Int       @id @default(autoincrement())
  orderId   Int       @map("order_id")
  dishId    Int       @map("dish_id")
  quantity  Decimal   @default(1.0) @db.Decimal(3, 1) // 支持一位小数，最大值99.9
  weight    String?   @db.VarChar(20) // 如5两，1斤
  status    String    @default("pending") @db.VarChar(20) // pending → prep → ready → served → cancelled
  priority  Int       @default(0) // 优先级：0-未起菜，1-不急，2-等一下，3-催菜，-1-已出
  remark    String? // 备注
  servedAt  DateTime? @map("served_at") // 上菜时间
  createdAt DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  dish  Dish  @relation(fields: [dishId], references: [id])

  @@map("order_items")
}

// 菜谱表
model Recipe {
  id             Int      @id @default(autoincrement())
  name           String   @unique @db.VarChar(100) // 菜品名称
  description    String? // 描述文字
  ingredientList String?  @map("ingredient_list") @db.Text // 用料
  images         String[] // 配图
  steps          String?  @db.Text // 做法
  tags           String[] // 标签
  createdAt      DateTime @default(now()) @map("created_at")
  dish_id        Int?     @map("dish_id") // 关联的菜品

  @@map("recipes")
}